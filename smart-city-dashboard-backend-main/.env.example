# Smart City Dashboard - Backend Configuration

# Server
PORT=3000
NODE_ENV=development

# API Tokens (get these from the respective services)
# Hystreet API: https://hystreet.com/api
HYSTREETS_API_TOKEN=your_hystreet_token_here

# Eco Counter API: https://www.eco-counter.com/
ECO_COUNTER_API_TOKEN=your_ecocounter_token_here

# DataHub Digital: https://datahub.digital/
DATAHUB_DIGITAL_TOKEN=your_datahub_token_here

# Redis Configuration
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# Data updates
# Update intervals in cron format
PARKING_UPDATE_INTERVAL=*/5 * * * *
PEDESTRIAN_UPDATE_INTERVAL=*/10 * * * *
BICYCLE_UPDATE_INTERVAL=0 * * * *
ZONE_UPDATE_INTERVAL=*/30 * * * *

# CORS
CORS_ENABLED=true
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
